# =============================================================================
# GitHub App
# =============================================================================

# From: github.com/settings/apps → your app → General
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_SECRET_NAME=       # Name of the secret in Azure Key Vault (not the key itself)
GITHUB_WEBHOOK_SECRET=                    # Set when creating the app; used to validate webhook signatures

# =============================================================================
# Azure — Identity and Subscription
# =============================================================================

AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=                          # Service principal or managed identity client ID

# =============================================================================
# Azure — Resource Group and Location
# =============================================================================

AZURE_RESOURCE_GROUP=
AZURE_LOCATION=

# =============================================================================
# Azure Key Vault
# =============================================================================

AZURE_KEY_VAULT_NAME=
AZURE_KEY_VAULT_URI=

# =============================================================================
# Azure Service Bus
# =============================================================================

AZURE_SERVICE_BUS_NAMESPACE=
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_QUEUE_NAME=             # e.g. pr-events

# =============================================================================
# Azure Container Apps
# =============================================================================

AZURE_CONTAINER_APP_ENVIRONMENT=
AZURE_CONTAINER_REGISTRY=                 # e.g. myregistry.azurecr.io
AZURE_CONTAINER_REGISTRY_USERNAME=
AZURE_CONTAINER_REGISTRY_PASSWORD=

# =============================================================================
# Azure PostgreSQL
# =============================================================================

POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=                        # Store the actual value in Key Vault; reference it here for local dev only
POSTGRES_SSL_MODE=require

# =============================================================================
# Azure Blob Storage (artifacts: screenshots, traces, videos, logs)
# =============================================================================

AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER_ARTIFACTS=        # e.g. qa-artifacts
AZURE_STORAGE_CONNECTION_STRING=

# =============================================================================
# Azure AI Foundry / Azure OpenAI
# =============================================================================

AZURE_OPENAI_ENDPOINT=                    # e.g. https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=                     # Store in Key Vault; reference here for local dev only
AZURE_OPENAI_DEPLOYMENT_HIGH=             # High-capability model deployment name (planning, summarization)
AZURE_OPENAI_DEPLOYMENT_LOW=              # Lower-cost model deployment name (extraction, labeling)
AZURE_OPENAI_API_VERSION=                 # e.g. 2024-02-01

# =============================================================================
# Azure Application Insights / OpenTelemetry
# =============================================================================

APPLICATIONINSIGHTS_CONNECTION_STRING=
OTEL_SERVICE_NAME=                        # e.g. preview-qa-agent
OTEL_EXPORTER_OTLP_ENDPOINT=              # If using a custom OTLP collector

# =============================================================================
# Vercel (preview URL resolution)
# =============================================================================

VERCEL_API_TOKEN=
VERCEL_TEAM_ID=                           # Optional; required for team-scoped deployments
VERCEL_TOKEN=

# =============================================================================
# Webhook receiver (Azure Functions)
# =============================================================================

WEBHOOK_FUNCTION_URL=                     # Public URL of the deployed webhook function
WEBHOOK_FUNCTION_KEY=                     # Host key for the Azure Function

# =============================================================================
# Local development only — do not set in production
# =============================================================================

# NODE_ENV=development
# LOG_LEVEL=debug
